# ============================================
# .gitignore - CyberPath Digital
# ============================================

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Node modules (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build files
dist/
build/
*.min.js
*.min.css

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Cache
.cache/
*.cache

# Temporary files
tmp/
temp/
*.tmp

# Package lock files (optional)
package-lock.json
yarn.lock

# User-specific files
*.user
*.userworkspace

# Backup files
*.bak
*.backup

# System files
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/

# TypeScript
*.tsbuildinfo

# Next.js
.next/
out/

# Nuxt.js
.nuxt/
dist/

# Gatsby
.cache/
public/

# Storybook
storybook-static/

# Testing
coverage/

# Production
*.log
*.lock
*.pid
